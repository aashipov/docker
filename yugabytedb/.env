# Interpolation in docker-compose.yml & Dockerfile
COMPOSE_PROJECT_NAME=yb
YUGABYTE_IMAGE=yugabytedb/yugabyte:2025.2.1.0-b141

# Set database, user & password up
POSTGRES=postgres
POSTGRES_HOST=${POSTGRES}
POSTGRES_DB=${POSTGRES}
POSTGRES_USER=${POSTGRES}
POSTGRES_PASSWORD=${POSTGRES}
PGUSER=${POSTGRES}
